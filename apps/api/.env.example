APP_NAME=TalentlyAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

POSTGRES_DB=talently
POSTGRES_USER=talently
POSTGRES_PASSWORD=talently
POSTGRES_PORT=5433

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=talently
DB_USERNAME=talently
DB_PASSWORD=talently
DB_SSLMODE=prefer

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
API_RATE_LIMIT_PER_MINUTE=60

# Optional AI provider variables for future scoring modules
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
